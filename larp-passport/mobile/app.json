{
  "expo": {
    "name": "LARP Passport",
    "slug": "larp-passport",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f1210",
    "android": {
      "package": "com.larppassport.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1210"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "LARP Passport shares your location with your game masters only while you have consented, during a game."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "b8136a6c-35fb-4319-b1ad-e3c0b6ee6805"
      }
    }
  }
}
